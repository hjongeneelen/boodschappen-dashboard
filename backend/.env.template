# ─── Local Vision LLM ────────────────────────────────────────────────────────
# Ollama    → http://localhost:11434/v1   |  LLM_API_KEY=ollama
# LM Studio → http://localhost:1234/v1   |  LLM_API_KEY=lmstudio
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llava:13b
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ─── PDF Processing ──────────────────────────────────────────────────────────
PDF_DPI=200
MAX_PAGES_PER_PDF=20

# ─────────────────────────────────────────────────────────────────────────────
# STORE PDF URL OVERRIDES
# ─────────────────────────────────────────────────────────────────────────────
# All fields below are OPTIONAL.
# Leave blank → auto-discovery runs (works for all Tier A and B stores).
# Paste a direct .pdf URL → skips scraping entirely for that store.
# ─────────────────────────────────────────────────────────────────────────────

# ── Tier A: Fully automatable (week-number URL / predictable Publitas slug) ──
# These almost never need manual overrides.
HOOGVLIET_PDF_URL=
BONI_PDF_URL=
POIESZ_PDF_URL=
DA_DROGIST_PDF_URL=

# ── Tier B: Publitas API discovery (auto, but paste URL if it fails) ─────────
JUMBO_PDF_URL=
COOP_PDF_URL=
KRUIDVAT_PDF_URL=
ETOS_PDF_URL=
NETTORAMA_PDF_URL=
PLUS_PDF_URL=
DEKAMARKT_PDF_URL=
BLOKKER_PDF_URL=
GAMMA_PDF_URL=
PRAXIS_PDF_URL=

# ── Tier C: Must be set manually each week ───────────────────────────────────
# Aldi: open aldi.nl/aanbiedingen in Chrome, DevTools → Network → filter pdf
ALDI_PDF_URL=
# Dirk: no PDF — uses direct JPG scraping from web-fileserver.dirk.nl
# Albert Heijn: uses JSON API connector — no URL needed
# Lidl: uses JSON API connector — no URL needed
